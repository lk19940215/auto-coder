{
  "version": "2.9",
  "imports": { "sys": "../system.lib.pen" },
  "children": [
    {
      "type": "frame",
      "id": "page-root",
      "x": 0,
      "y": 0,
      "width": 1440,
      "fill": "$sys:color.bg",
      "layout": "vertical",
      "children": [
        {
          "type": "ref",
          "id": "section-header",
          "ref": "sys:header",
          "descendants": {
            "sys:header-brand": { "content": "Claude Coder" },
            "sys:nav-home": { "content": "首页", "fill": "$sys:color.text" },
            "sys:nav-quickstart": { "content": "快速上手" },
            "sys:nav-features": { "content": "功能特性" },
            "sys:nav-docs": { "content": "文档" },
            "sys:nav-examples": { "content": "案例" },
            "sys:nav-browser": { "content": "浏览器工具" },
            "sys:header-github": { "content": "Star" },
            "sys:header-cta-label": { "content": "下载安装" }
          }
        },
        {
          "type": "frame",
          "id": "hero-section",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 32,
          "padding": [128, 32],
          "alignItems": "center",
          "children": [
            {
              "type": "text",
              "id": "hero-title",
              "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#8B5CF6","position":0},{"color":"#EC4899","position":1}], "rotation": 90 },
              "content": "Claude Coder",
              "fontFamily": "Inter, system-ui, sans-serif",
              "fontSize": 60,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "hero-subtitle",
              "fill": "$sys:color.cyan",
              "content": "摸鱼神器 🐟",
              "fontFamily": "Inter, system-ui, sans-serif",
              "fontSize": 24,
              "fontWeight": "600"
            },
            {
              "type": "frame",
              "id": "hero-desc",
              "layout": "vertical",
              "gap": 8,
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "hero-desc-line1",
                  "fill": "$sys:color.text-muted",
                  "content": "AI 加班你摸鱼，Claude Coder 帮你搞定一切。",
                  "fontFamily": "Inter, system-ui, sans-serif",
                  "fontSize": 18,
                  "lineHeight": 1.6
                },
                {
                  "type": "text",
                  "id": "hero-desc-line2",
                  "fill": "$sys:color.text-muted",
                  "content": "一句话需求 → 完整项目。长时间自运行，自动分解任务、持续编码、验证交付。",
                  "fontFamily": "Inter, system-ui, sans-serif",
                  "fontSize": 18,
                  "lineHeight": 1.6
                }
              ]
            },
            {
              "type": "frame",
              "id": "hero-buttons",
              "gap": 16,
              "alignItems": "center",
              "children": [
                {
                  "type": "ref",
                  "id": "hero-cta-btn",
                  "ref": "sys:btn-primary",
                  "descendants": {
                    "sys:btn-primary-label": { "content": "开始使用" }
                  }
                },
                {
                  "type": "text",
                  "id": "hero-github-link",
                  "fill": "$sys:color.text-muted",
                  "content": "View on GitHub",
                  "fontFamily": "Inter, system-ui, sans-serif",
                  "fontSize": 14
                }
              ]
            },
            {
              "type": "frame",
              "id": "hero-stats",
              "gap": 48,
              "padding": [64, 0, 0, 0],
              "children": [
                {
                  "type": "ref",
                  "id": "stat-1",
                  "ref": "sys:stat-item",
                  "descendants": {
                    "sys:stat-value": { "content": "50+" },
                    "sys:stat-label": { "content": "Sessions 自动运行" }
                  }
                },
                {
                  "type": "ref",
                  "id": "stat-2",
                  "ref": "sys:stat-item",
                  "descendants": {
                    "sys:stat-value": { "content": "∞" },
                    "sys:stat-label": { "content": "模型支持" }
                  }
                },
                {
                  "type": "ref",
                  "id": "stat-3",
                  "ref": "sys:stat-item",
                  "descendants": {
                    "sys:stat-value": { "content": "0" },
                    "sys:stat-label": { "content": "配置即开即用" }
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "features-section",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 64,
          "padding": [80, 32],
          "children": [
            {
              "type": "frame",
              "id": "features-header",
              "layout": "vertical",
              "gap": 16,
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "features-title",
                  "fill": "$sys:color.text",
                  "content": "核心特性",
                  "fontFamily": "Inter, system-ui, sans-serif",
                  "fontSize": 36,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "features-subtitle",
                  "fill": "$sys:color.text-muted",
                  "content": "让 AI 成为真正的编码伙伴，从需求到交付，全程自主执行",
                  "fontFamily": "Inter, system-ui, sans-serif",
                  "fontSize": 18,
                  "textGrowth": "fixed-width",
                  "width": 600,
                  "textAlign": "center"
                }
              ]
            },
            {
              "type": "frame",
              "id": "features-grid",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 32,
              "children": [
                {
                  "type": "frame",
                  "id": "features-row-1",
                  "width": "fill_container",
                  "gap": 32,
                  "children": [
                    {
                      "type": "ref",
                      "id": "feature-1",
                      "ref": "sys:feature-card",
                      "width": "fill_container",
                      "descendants": {
                        "sys:feature-card-icon-symbol": { "content": "⚡" },
                        "sys:feature-card-title": { "content": "一句话需求 → 完整项目" },
                        "sys:feature-card-desc": { "content": "告别繁琐的手动编码。自然语言描述需求，AI 自动分解为可执行任务队列，从零到交付一气呵成。", "width": "fill_container" }
                      }
                    },
                    {
                      "type": "ref",
                      "id": "feature-2",
                      "ref": "sys:feature-card",
                      "width": "fill_container",
                      "descendants": {
                        "sys:feature-card-icon-symbol": { "content": "🔄" },
                        "sys:feature-card-title": { "content": "数小时无人值守" },
                        "sys:feature-card-desc": { "content": "Session 守护 + 倒计时活跃度监控 + git 回滚重试，Agent 持续编码数小时不中断，真正解放双手。", "width": "fill_container" }
                      }
                    },
                    {
                      "type": "ref",
                      "id": "feature-3",
                      "ref": "sys:feature-card",
                      "width": "fill_container",
                      "descendants": {
                        "sys:feature-card-icon-symbol": { "content": "🛡" },
                        "sys:feature-card-title": { "content": "Hook 注入 · 安全可控" },
                        "sys:feature-card-desc": { "content": "JSON 配置即可在工具调用时注入规则引导，零代码修改扩展 AI 行为，代码审查自动护航。", "width": "fill_container" }
                      }
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "features-row-2",
                  "width": "fill_container",
                  "gap": 32,
                  "children": [
                    {
                      "type": "ref",
                      "id": "feature-4",
                      "ref": "sys:feature-card",
                      "width": "fill_container",
                      "descendants": {
                        "sys:feature-card-icon-symbol": { "content": "🔀" },
                        "sys:feature-card-title": { "content": "任意模型 · 自由切换" },
                        "sys:feature-card-desc": { "content": "支持 Claude、DeepSeek、GLM-5、Qwen 等任意 Anthropic 兼容 API，多模型路由灵活编排。", "width": "fill_container" }
                      }
                    },
                    {
                      "type": "ref",
                      "id": "feature-5",
                      "ref": "sys:feature-card",
                      "width": "fill_container",
                      "descendants": {
                        "sys:feature-card-icon-symbol": { "content": "🧪" },
                        "sys:feature-card-title": { "content": "E2E 测试自动化" },
                        "sys:feature-card-desc": { "content": "Playwright 登录态一键导出、API Key 持久化存储，Agent 编码后自动验证，交付即可用。", "width": "fill_container" }
                      }
                    },
                    {
                      "type": "ref",
                      "id": "feature-6",
                      "ref": "sys:feature-card",
                      "width": "fill_container",
                      "descendants": {
                        "sys:feature-card-icon-symbol": { "content": "⚙" },
                        "sys:feature-card-title": { "content": "配置驱动 · 开箱即用" },
                        "sys:feature-card-desc": { "content": "JSON 配置 + 环境变量 + CLI 参数三位一体，claude-coder setup 一键配好，即刻开跑。", "width": "fill_container" }
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "howitworks-section",
          "width": "fill_container",
          "fill": "$sys:color.bg-card",
          "layout": "vertical",
          "gap": 64,
          "padding": [80, 32],
          "children": [
            {
              "type": "frame",
              "id": "howitworks-header",
              "layout": "vertical",
              "gap": 16,
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "howitworks-title",
                  "fill": "$sys:color.text",
                  "content": "工作原理",
                  "fontFamily": "Inter, system-ui, sans-serif",
                  "fontSize": 36,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "howitworks-subtitle",
                  "fill": "$sys:color.text-muted",
                  "content": "四步完成从需求到交付的完整流程",
                  "fontFamily": "Inter, system-ui, sans-serif",
                  "fontSize": 18,
                  "textAlign": "center"
                }
              ]
            },
            {
              "type": "frame",
              "id": "howitworks-steps",
              "width": "fill_container",
              "gap": 32,
              "children": [
                {
                  "type": "ref",
                  "id": "step-1",
                  "ref": "sys:step-card",
                  "width": "fill_container",
                  "descendants": {
                    "sys:step-card-num-text": { "content": "1" },
                    "sys:step-card-title": { "content": "描述需求" },
                    "sys:step-card-desc": { "content": "一句话或 requirements.md，用自然语言告诉 AI 你想要什么。", "width": "fill_container" }
                  }
                },
                {
                  "type": "ref",
                  "id": "step-2",
                  "ref": "sys:step-card",
                  "width": "fill_container",
                  "descendants": {
                    "sys:step-card-num-text": { "content": "2" },
                    "sys:step-card-title": { "content": "智能分解" },
                    "sys:step-card-desc": { "content": "AI 自动扫描项目技术栈，将需求拆分为可执行任务并按依赖排序。", "width": "fill_container" }
                  }
                },
                {
                  "type": "ref",
                  "id": "step-3",
                  "ref": "sys:step-card",
                  "width": "fill_container",
                  "descendants": {
                    "sys:step-card-num-text": { "content": "3" },
                    "sys:step-card-title": { "content": "持续编码" },
                    "sys:step-card-desc": { "content": "Agent 多 Session 循环编码，生成代码、处理依赖、运行测试，自动 git commit。", "width": "fill_container" }
                  }
                },
                {
                  "type": "ref",
                  "id": "step-4",
                  "ref": "sys:step-card",
                  "width": "fill_container",
                  "descendants": {
                    "sys:step-card-num-text": { "content": "4" },
                    "sys:step-card-title": { "content": "验证交付" },
                    "sys:step-card-desc": { "content": "每个 Session 自动验证功能，失败则 git 回滚重试，通过即产出可用代码。", "width": "fill_container" }
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "cta-section",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 32,
          "padding": [80, 32],
          "alignItems": "center",
          "children": [
            {
              "type": "frame",
              "id": "cta-card",
              "width": 896,
              "fill": "$sys:color.bg-card",
              "stroke": { "align": "inside", "thickness": 1, "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#8B5CF6","position":0},{"color":"#EC4899","position":1}], "rotation": 135 } },
              "cornerRadius": 16,
              "layout": "vertical",
              "gap": 24,
              "padding": 48,
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "cta-title",
                  "fill": "$sys:color.text",
                  "content": "准备好开始了吗？",
                  "fontFamily": "Inter, system-ui, sans-serif",
                  "fontSize": 36,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "cta-desc",
                  "fill": "$sys:color.text-muted",
                  "content": "几分钟内配置完成，立即体验自主编码 Agent 的强大能力。",
                  "fontFamily": "Inter, system-ui, sans-serif",
                  "fontSize": 18,
                  "textAlign": "center"
                },
                {
                  "type": "frame",
                  "id": "cta-buttons",
                  "gap": 16,
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "ref",
                      "id": "cta-btn",
                      "ref": "sys:btn-primary",
                      "descendants": {
                        "sys:btn-primary-label": { "content": "快速开始" }
                      }
                    },
                    {
                      "type": "text",
                      "id": "cta-docs-link",
                      "fill": "$sys:color.text-muted",
                      "content": "阅读文档 →",
                      "fontFamily": "Inter, system-ui, sans-serif",
                      "fontSize": 16
                    }
                  ]
                },
                {
                  "type": "ref",
                  "id": "cta-terminal",
                  "ref": "sys:terminal",
                  "y": 24
                }
              ]
            }
          ]
        },
        {
          "type": "ref",
          "id": "section-footer",
          "ref": "sys:footer",
          "descendants": {
            "sys:footer-brand": { "content": "Claude Coder" },
            "sys:footer-desc": { "content": "长时间自运行的自主编码 Agent Harness，一句话需求 → 完整项目。" },
            "sys:footer-link-1": { "content": "快速上手" },
            "sys:footer-link-2": { "content": "功能特性" },
            "sys:footer-link-3": { "content": "文档" },
            "sys:footer-link-4": { "content": "GitHub" },
            "sys:footer-copyright": { "content": "© 2026 Claude Coder. Licensed under MIT." }
          }
        }
      ]
    }
  ]
}