{
  "version": "2.9",
  "children": [
    {
      "type": "frame",
      "id": "header",
      "x": 0,
      "y": 0,
      "reusable": true,
      "width": 1440,
      "height": 64,
      "fill": "$color.bg",
      "stroke": { "align": "inside", "thickness": 1, "fill": "$color.border" },
      "padding": [0, 32],
      "justifyContent": "space_between",
      "alignItems": "center",
      "children": [
        {
          "type": "frame",
          "id": "header-logo-group",
          "gap": 12,
          "alignItems": "center",
          "children": [
            {
              "type": "frame",
              "id": "header-logo-icon",
              "width": 32,
              "height": 32,
              "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#8B5CF6","position":0},{"color":"#EC4899","position":1}], "rotation": 135 },
              "cornerRadius": 8,
              "justifyContent": "center",
              "alignItems": "center",
              "children": [
                { "type": "text", "id": "header-logo-letter", "fill": "#FFFFFF", "content": "C", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 18, "fontWeight": "700" }
              ]
            },
            { "type": "text", "id": "header-brand", "fill": "$color.text", "content": "Claude Coder", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 20, "fontWeight": "700" }
          ]
        },
        {
          "type": "frame",
          "id": "header-nav",
          "gap": 32,
          "alignItems": "center",
          "children": [
            { "type": "text", "id": "nav-home", "fill": "$color.text", "content": "首页", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14, "fontWeight": "500" },
            { "type": "text", "id": "nav-quickstart", "fill": "$color.text-muted", "content": "快速上手", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
            { "type": "text", "id": "nav-features", "fill": "$color.text-muted", "content": "功能特性", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
            { "type": "text", "id": "nav-docs", "fill": "$color.text-muted", "content": "文档", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
            { "type": "text", "id": "nav-examples", "fill": "$color.text-muted", "content": "案例", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
            { "type": "text", "id": "nav-browser", "fill": "$color.text-muted", "content": "浏览器工具", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 }
          ]
        },
        {
          "type": "frame",
          "id": "header-actions",
          "gap": 16,
          "alignItems": "center",
          "children": [
            { "type": "text", "id": "header-github", "fill": "$color.text-muted", "content": "Star", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
            {
              "type": "frame",
              "id": "header-cta-btn",
              "width": 100,
              "height": 36,
              "fill": "$color.primary",
              "cornerRadius": 8,
              "justifyContent": "center",
              "alignItems": "center",
              "children": [
                { "type": "text", "id": "header-cta-label", "fill": "#FFFFFF", "content": "下载安装", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14, "fontWeight": "600" }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "frame",
      "id": "btn-primary",
      "x": 0,
      "y": 100,
      "reusable": true,
      "width": 160,
      "height": 48,
      "fill": "$color.primary",
      "cornerRadius": 12,
      "justifyContent": "center",
      "alignItems": "center",
      "children": [
        {
          "type": "text",
          "id": "btn-primary-label",
          "fill": "#FFFFFF",
          "content": "按钮",
          "fontFamily": "Inter, system-ui, sans-serif",
          "fontSize": 16,
          "fontWeight": "600"
        }
      ]
    },
    {
      "type": "frame",
      "id": "feature-card",
      "x": 0,
      "y": 200,
      "reusable": true,
      "width": 400,
      "height": 200,
      "fill": "$color.bg-card",
      "stroke": { "align": "inside", "thickness": 1, "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#8B5CF6","position":0},{"color":"#EC4899","position":1}], "rotation": 135 } },
      "cornerRadius": 12,
      "layout": "vertical",
      "gap": 16,
      "padding": 24,
      "children": [
        {
          "type": "frame",
          "id": "feature-card-icon",
          "width": 48,
          "height": 48,
          "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#8B5CF6","position":0},{"color":"#EC4899","position":1}], "rotation": 135 },
          "cornerRadius": 8,
          "justifyContent": "center",
          "alignItems": "center",
          "children": [
            { "type": "text", "id": "feature-card-icon-symbol", "fill": "#FFFFFF", "content": "⚡", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 24 }
          ]
        },
        {
          "type": "text",
          "id": "feature-card-title",
          "fill": "$color.text",
          "content": "功能标题",
          "fontFamily": "Inter, system-ui, sans-serif",
          "fontSize": 20,
          "fontWeight": "600"
        },
        {
          "type": "text",
          "id": "feature-card-desc",
          "fill": "$color.text-muted",
          "content": "功能描述文字占位",
          "fontFamily": "Inter, system-ui, sans-serif",
          "fontSize": 14,
          "textGrowth": "fixed-width",
          "width": 352,
          "lineHeight": 1.5
        }
      ]
    },
    {
      "type": "frame",
      "id": "step-card",
      "x": 0,
      "y": 450,
      "reusable": true,
      "width": 300,
      "height": 180,
      "fill": "$color.bg-card",
      "cornerRadius": 12,
      "layout": "vertical",
      "gap": 16,
      "padding": 24,
      "alignItems": "center",
      "children": [
        {
          "type": "frame",
          "id": "step-card-number",
          "width": 48,
          "height": 48,
          "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#8B5CF6","position":0},{"color":"#EC4899","position":1}], "rotation": 135 },
          "cornerRadius": 24,
          "justifyContent": "center",
          "alignItems": "center",
          "children": [
            { "type": "text", "id": "step-card-num-text", "fill": "#FFFFFF", "content": "1", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 18, "fontWeight": "700" }
          ]
        },
        {
          "type": "text",
          "id": "step-card-title",
          "fill": "$color.text",
          "content": "步骤标题",
          "fontFamily": "Inter, system-ui, sans-serif",
          "fontSize": 20,
          "fontWeight": "600"
        },
        {
          "type": "text",
          "id": "step-card-desc",
          "fill": "$color.text-muted",
          "content": "步骤描述文字占位",
          "fontFamily": "Inter, system-ui, sans-serif",
          "fontSize": 14,
          "textGrowth": "fixed-width",
          "width": 252,
          "lineHeight": 1.5,
          "textAlign": "center"
        }
      ]
    },
    {
      "type": "frame",
      "id": "stat-item",
      "x": 0,
      "y": 680,
      "reusable": true,
      "width": 160,
      "height": 80,
      "layout": "vertical",
      "gap": 8,
      "alignItems": "center",
      "children": [
        { "type": "text", "id": "stat-value", "fill": "$color.text", "content": "50+", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 30, "fontWeight": "700" },
        { "type": "text", "id": "stat-label", "fill": "$color.text-muted", "content": "Sessions 自动运行", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 }
      ]
    },
    {
      "type": "frame",
      "id": "terminal",
      "x": 0,
      "y": 800,
      "reusable": true,
      "width": 800,
      "height": 200,
      "fill": "#0D1117",
      "cornerRadius": 12,
      "layout": "vertical",
      "padding": 0,
      "children": [
        {
          "type": "frame",
          "id": "terminal-header",
          "width": "fill_container",
          "height": 36,
          "fill": "#161B22",
          "cornerRadius": [12, 12, 0, 0],
          "gap": 8,
          "padding": [0, 16],
          "alignItems": "center",
          "children": [
            { "type": "ellipse", "id": "terminal-dot-red", "width": 12, "height": 12, "fill": "#FF5F56" },
            { "type": "ellipse", "id": "terminal-dot-yellow", "width": 12, "height": 12, "fill": "#FFBD2E" },
            { "type": "ellipse", "id": "terminal-dot-green", "width": 12, "height": 12, "fill": "#27C93F" },
            { "type": "text", "id": "terminal-title", "fill": "$color.text-muted", "content": "Terminal", "fontFamily": "Menlo, Monaco, monospace", "fontSize": 12 }
          ]
        },
        {
          "type": "frame",
          "id": "terminal-body",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 8,
          "padding": 16,
          "children": [
            { "type": "text", "id": "terminal-cmd", "fill": "#22C55E", "content": "$ claude-coder run \"创建个人博客\"", "fontFamily": "Menlo, Monaco, monospace", "fontSize": 14 },
            { "type": "text", "id": "terminal-line1", "fill": "$color.text-muted", "content": "✓ 分析需求...", "fontFamily": "Menlo, Monaco, monospace", "fontSize": 14 },
            { "type": "text", "id": "terminal-line2", "fill": "$color.text-muted", "content": "✓ 生成任务计划 (5 个任务)", "fontFamily": "Menlo, Monaco, monospace", "fontSize": 14 },
            { "type": "text", "id": "terminal-line3", "fill": "$color.text-muted", "content": "✓ 开始编码 Session 1/5", "fontFamily": "Menlo, Monaco, monospace", "fontSize": 14 }
          ]
        }
      ]
    },
    {
      "type": "frame",
      "id": "footer",
      "x": 0,
      "y": 1100,
      "reusable": true,
      "width": 1440,
      "height": 280,
      "fill": "$color.bg-card",
      "layout": "vertical",
      "gap": 32,
      "padding": [48, 32],
      "children": [
        {
          "type": "frame",
          "id": "footer-columns",
          "gap": 32,
          "width": "fill_container",
          "children": [
            {
              "type": "frame",
              "id": "footer-brand-col",
              "layout": "vertical",
              "gap": 16,
              "width": "fill_container",
              "children": [
                {
                  "type": "frame",
                  "id": "footer-logo-group",
                  "gap": 12,
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "frame",
                      "id": "footer-logo-icon",
                      "width": 32,
                      "height": 32,
                      "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#8B5CF6","position":0},{"color":"#EC4899","position":1}], "rotation": 135 },
                      "cornerRadius": 8,
                      "justifyContent": "center",
                      "alignItems": "center",
                      "children": [
                        { "type": "text", "id": "footer-logo-letter", "fill": "#FFFFFF", "content": "C", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 18, "fontWeight": "700" }
                      ]
                    },
                    { "type": "text", "id": "footer-brand", "fill": "$color.text", "content": "Claude Coder", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 20, "fontWeight": "700" }
                  ]
                },
                { "type": "text", "id": "footer-desc", "fill": "$color.text-muted", "content": "长时间自运行的自主编码 Agent Harness，一句话需求 → 完整项目。", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14, "textGrowth": "fixed-width", "width": 300 }
              ]
            },
            {
              "type": "frame",
              "id": "footer-links-col",
              "layout": "vertical",
              "gap": 12,
              "width": "fill_container",
              "children": [
                { "type": "text", "id": "footer-links-title", "fill": "$color.text", "content": "快速链接", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14, "fontWeight": "600" },
                { "type": "text", "id": "footer-link-1", "fill": "$color.text-muted", "content": "快速上手", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
                { "type": "text", "id": "footer-link-2", "fill": "$color.text-muted", "content": "功能特性", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
                { "type": "text", "id": "footer-link-3", "fill": "$color.text-muted", "content": "文档", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
                { "type": "text", "id": "footer-link-4", "fill": "$color.text-muted", "content": "GitHub", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 }
              ]
            },
            {
              "type": "frame",
              "id": "footer-social-col",
              "layout": "vertical",
              "gap": 12,
              "width": "fill_container",
              "children": [
                { "type": "text", "id": "footer-social-title", "fill": "$color.text", "content": "关注我们", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14, "fontWeight": "600" },
                {
                  "type": "frame",
                  "id": "footer-social-icons",
                  "gap": 16,
                  "children": [
                    { "type": "text", "id": "social-twitter", "fill": "$color.text-muted", "content": "𝕏", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 18 },
                    { "type": "text", "id": "social-discord", "fill": "$color.text-muted", "content": "Discord", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
                    { "type": "text", "id": "social-youtube", "fill": "$color.text-muted", "content": "YouTube", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "footer-bottom",
          "width": "fill_container",
          "stroke": { "align": "inside", "thickness": 1, "fill": "$color.border" },
          "padding": [16, 0, 0, 0],
          "justifyContent": "center",
          "children": [
            { "type": "text", "id": "footer-copyright", "fill": "$color.text-muted", "content": "© 2026 Claude Coder. Licensed under MIT.", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14, "textAlign": "center" }
          ]
        }
      ]
    }
  ],
  "themes": { "mode": ["light", "dark"] },
  "variables": {
    "color.primary": { "type": "color", "value": "#8B5CF6" },
    "color.bg": { "type": "color", "value": "#0F172A" },
    "color.bg-card": { "type": "color", "value": "#1E293B" },
    "color.text": { "type": "color", "value": "#FFFFFF" },
    "color.text-muted": { "type": "color", "value": "#94A3B8" },
    "color.border": { "type": "color", "value": "#334155" },
    "color.cyan": { "type": "color", "value": "#22D3EE" },
    "spacing.sm": { "type": "number", "value": 8 },
    "spacing.md": { "type": "number", "value": 16 },
    "spacing.lg": { "type": "number", "value": 24 },
    "spacing.xl": { "type": "number", "value": 32 },
    "spacing.2xl": { "type": "number", "value": 48 },
    "radius.md": { "type": "number", "value": 8 },
    "radius.lg": { "type": "number", "value": 12 },
    "radius.xl": { "type": "number", "value": 16 },
    "font.primary": { "type": "string", "value": "Inter, system-ui, sans-serif" }
  }
}