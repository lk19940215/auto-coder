{
  "version": "2.9",
  "children": [
    {
      "type": "frame",
      "id": "header",
      "x": 0,
      "y": 0,
      "reusable": true,
      "width": 1440,
      "height": 64,
      "fill": "$color.bg",
      "stroke": { "align": "inside", "thickness": 1, "fill": "$color.border" },
      "padding": [0, 32],
      "justifyContent": "space_between",
      "alignItems": "center",
      "children": [
        {
          "type": "frame",
          "id": "header-logo-group",
          "gap": 12,
          "alignItems": "center",
          "children": [
            {
              "type": "frame",
              "id": "header-logo-icon",
              "width": 32,
              "height": 32,
              "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#8B5CF6","position":0},{"color":"#EC4899","position":1}], "rotation": 135 },
              "cornerRadius": 8,
              "justifyContent": "center",
              "alignItems": "center",
              "children": [
                { "type": "text", "id": "header-logo-letter", "fill": "#FFFFFF", "content": "C", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 18, "fontWeight": "700" }
              ]
            },
            { "type": "text", "id": "header-logo-text", "fill": "$color.text", "content": "Claude Coder", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 20, "fontWeight": "700" }
          ]
        },
        {
          "type": "frame",
          "id": "header-nav",
          "gap": 32,
          "alignItems": "center",
          "children": [
            { "type": "text", "id": "nav-home", "fill": "$color.text", "content": "首页", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14, "fontWeight": "500" },
            { "type": "text", "id": "nav-quick-start", "fill": "$color.text-muted", "content": "快速上手", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
            { "type": "text", "id": "nav-features", "fill": "$color.text-muted", "content": "功能特性", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
            { "type": "text", "id": "nav-docs", "fill": "$color.text-muted", "content": "文档", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
            { "type": "text", "id": "nav-examples", "fill": "$color.text-muted", "content": "案例", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
            { "type": "text", "id": "nav-browser-tools", "fill": "$color.text-muted", "content": "浏览器工具", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 }
          ]
        },
        {
          "type": "frame",
          "id": "header-actions",
          "gap": 16,
          "alignItems": "center",
          "children": [
            { "type": "text", "id": "header-github", "fill": "$color.text-muted", "content": "Star", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
            {
              "type": "frame",
              "id": "header-cta-btn",
              "width": 96,
              "height": 36,
              "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#8B5CF6","position":0},{"color":"#EC4899","position":1}], "rotation": 135 },
              "cornerRadius": 8,
              "justifyContent": "center",
              "alignItems": "center",
              "children": [
                { "type": "text", "id": "header-cta-text", "fill": "#FFFFFF", "content": "下载安装", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14, "fontWeight": "600" }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "frame",
      "id": "btn-primary",
      "x": 0,
      "y": 100,
      "reusable": true,
      "width": 140,
      "height": 48,
      "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#8B5CF6","position":0},{"color":"#EC4899","position":1}], "rotation": 135 },
      "cornerRadius": 8,
      "justifyContent": "center",
      "alignItems": "center",
      "children": [
        { "type": "text", "id": "btn-primary-label", "fill": "#FFFFFF", "content": "开始使用", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 16, "fontWeight": "600" }
      ]
    },
    {
      "type": "frame",
      "id": "card",
      "x": 0,
      "y": 200,
      "reusable": true,
      "width": 400,
      "height": 200,
      "fill": "$color.bg-card",
      "stroke": { "align": "inside", "thickness": 2, "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#8B5CF6","position":0},{"color":"#EC4899","position":1}], "rotation": 135 } },
      "cornerRadius": 16,
      "layout": "vertical",
      "gap": 16,
      "padding": 24,
      "children": [
        {
          "type": "frame",
          "id": "card-icon",
          "width": 48,
          "height": 48,
          "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#8B5CF6","position":0},{"color":"#EC4899","position":1}], "rotation": 135 },
          "cornerRadius": 8,
          "justifyContent": "center",
          "alignItems": "center",
          "children": [
            { "type": "text", "id": "card-icon-symbol", "fill": "#FFFFFF", "content": "⚡", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 24 }
          ]
        },
        { "type": "text", "id": "card-title", "fill": "$color.text", "content": "标题占位", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 20, "fontWeight": "600" },
        { "type": "text", "id": "card-desc", "fill": "$color.text-muted", "content": "描述文字占位", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14, "textGrowth": "fixed-width", "width": 352 }
      ]
    },
    {
      "type": "frame",
      "id": "stat-card",
      "x": 0,
      "y": 450,
      "reusable": true,
      "width": 200,
      "height": 80,
      "layout": "vertical",
      "gap": 4,
      "alignItems": "center",
      "children": [
        { "type": "text", "id": "stat-value", "fill": "$color.text", "content": "50+", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 30, "fontWeight": "700" },
        { "type": "text", "id": "stat-label", "fill": "$color.text-muted", "content": "统计说明", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 }
      ]
    },
    {
      "type": "frame",
      "id": "step-card",
      "x": 0,
      "y": 570,
      "reusable": true,
      "width": 280,
      "height": 200,
      "fill": "$color.bg-card",
      "stroke": { "align": "inside", "thickness": 2, "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#8B5CF6","position":0},{"color":"#EC4899","position":1}], "rotation": 135 } },
      "cornerRadius": 16,
      "layout": "vertical",
      "gap": 16,
      "padding": 24,
      "alignItems": "center",
      "children": [
        {
          "type": "frame",
          "id": "step-number",
          "width": 48,
          "height": 48,
          "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#8B5CF6","position":0},{"color":"#EC4899","position":1}], "rotation": 135 },
          "cornerRadius": 24,
          "justifyContent": "center",
          "alignItems": "center",
          "children": [
            { "type": "text", "id": "step-number-text", "fill": "#FFFFFF", "content": "1", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 18, "fontWeight": "700" }
          ]
        },
        { "type": "text", "id": "step-title", "fill": "$color.text", "content": "步骤标题", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 20, "fontWeight": "600" },
        { "type": "text", "id": "step-desc", "fill": "$color.text-muted", "content": "步骤描述文字", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14, "textGrowth": "fixed-width", "width": 232 }
      ]
    },
    {
      "type": "frame",
      "id": "terminal",
      "x": 0,
      "y": 820,
      "reusable": true,
      "width": 600,
      "height": 200,
      "fill": "#0D0D12",
      "cornerRadius": 12,
      "layout": "vertical",
      "clip": true,
      "children": [
        {
          "type": "frame",
          "id": "terminal-header",
          "width": "fill_container",
          "height": 36,
          "fill": "#1A1A22",
          "gap": 8,
          "padding": [0, 16],
          "alignItems": "center",
          "children": [
            { "type": "ellipse", "id": "terminal-dot-red", "width": 12, "height": 12, "fill": "#FF5F56" },
            { "type": "ellipse", "id": "terminal-dot-yellow", "width": 12, "height": 12, "fill": "#FFBD2E" },
            { "type": "ellipse", "id": "terminal-dot-green", "width": 12, "height": 12, "fill": "#27CA40" },
            { "type": "text", "id": "terminal-title", "fill": "$color.text-muted", "content": "Terminal", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 }
          ]
        },
        {
          "type": "frame",
          "id": "terminal-body",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 8,
          "padding": 16,
          "children": [
            { "type": "text", "id": "terminal-cmd", "fill": "#10B981", "content": "$ claude-coder run \"创建个人博客\"", "fontFamily": "Fira Code, Consolas, monospace", "fontSize": 14 },
            { "type": "text", "id": "terminal-line-1", "fill": "$color.text-muted", "content": "✓ 分析需求...", "fontFamily": "Fira Code, Consolas, monospace", "fontSize": 14 },
            { "type": "text", "id": "terminal-line-2", "fill": "$color.text-muted", "content": "✓ 生成任务计划 (5 个任务)", "fontFamily": "Fira Code, Consolas, monospace", "fontSize": 14 },
            { "type": "text", "id": "terminal-line-3", "fill": "$color.text-muted", "content": "✓ 开始编码 Session 1/5", "fontFamily": "Fira Code, Consolas, monospace", "fontSize": 14 }
          ]
        }
      ]
    },
    {
      "type": "frame",
      "id": "footer",
      "x": 0,
      "y": 1100,
      "reusable": true,
      "width": 1440,
      "height": 280,
      "fill": "$color.bg",
      "stroke": { "align": "inside", "thickness": 1, "fill": "$color.border" },
      "layout": "vertical",
      "gap": 32,
      "padding": 48,
      "children": [
        {
          "type": "frame",
          "id": "footer-columns",
          "gap": 32,
          "width": 1280,
          "children": [
            {
              "type": "frame",
              "id": "footer-brand-col",
              "layout": "vertical",
              "gap": 16,
              "width": "fill_container",
              "children": [
                {
                  "type": "frame",
                  "id": "footer-logo-group",
                  "gap": 12,
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "frame",
                      "id": "footer-logo-icon",
                      "width": 32,
                      "height": 32,
                      "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#8B5CF6","position":0},{"color":"#EC4899","position":1}], "rotation": 135 },
                      "cornerRadius": 8,
                      "justifyContent": "center",
                      "alignItems": "center",
                      "children": [
                        { "type": "text", "id": "footer-logo-letter", "fill": "#FFFFFF", "content": "C", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 18, "fontWeight": "700" }
                      ]
                    },
                    { "type": "text", "id": "footer-brand", "fill": "$color.text", "content": "Claude Coder", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 20, "fontWeight": "700" }
                  ]
                },
                { "type": "text", "id": "footer-desc", "fill": "$color.text-muted", "content": "长时间自运行的自主编码 Agent Harness，一句话需求 → 完整项目。", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14, "textGrowth": "fixed-width", "width": 350 }
              ]
            },
            {
              "type": "frame",
              "id": "footer-links-col",
              "layout": "vertical",
              "gap": 8,
              "width": "fill_container",
              "children": [
                { "type": "text", "id": "footer-links-title", "fill": "$color.text", "content": "快速链接", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14, "fontWeight": "600" },
                { "type": "text", "id": "footer-link-1", "fill": "$color.text-muted", "content": "快速上手", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
                { "type": "text", "id": "footer-link-2", "fill": "$color.text-muted", "content": "功能特性", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
                { "type": "text", "id": "footer-link-3", "fill": "$color.text-muted", "content": "文档", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
                { "type": "text", "id": "footer-link-4", "fill": "$color.text-muted", "content": "案例", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
                { "type": "text", "id": "footer-link-5", "fill": "$color.text-muted", "content": "GitHub", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 }
              ]
            },
            {
              "type": "frame",
              "id": "footer-social-col",
              "layout": "vertical",
              "gap": 8,
              "width": "fill_container",
              "children": [
                { "type": "text", "id": "footer-social-title", "fill": "$color.text", "content": "关注我们", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14, "fontWeight": "600" },
                {
                  "type": "frame",
                  "id": "footer-social-icons",
                  "gap": 16,
                  "children": [
                    { "type": "text", "id": "social-twitter", "fill": "$color.text-muted", "content": "𝕏", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 18 },
                    { "type": "text", "id": "social-discord", "fill": "$color.text-muted", "content": "Discord", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
                    { "type": "text", "id": "social-youtube", "fill": "$color.text-muted", "content": "YouTube", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "footer-bottom",
          "width": 1280,
          "stroke": { "align": "inside", "thickness": 1, "fill": "$color.border" },
          "padding": [16, 0, 0, 0],
          "justifyContent": "center",
          "children": [
            { "type": "text", "id": "footer-copyright", "fill": "$color.text-muted", "content": "© 2026 Claude Coder. Licensed under MIT.", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14, "textAlign": "center" }
          ]
        }
      ]
    }
  ],
  "themes": { "mode": ["dark"] },
  "variables": {
    "color.primary": { "type": "color", "value": "#8B5CF6" },
    "color.gradient-start": { "type": "color", "value": "#8B5CF6" },
    "color.gradient-end": { "type": "color", "value": "#EC4899" },
    "color.lazy-cyan": { "type": "color", "value": "#22D3EE" },
    "color.fish-gold": { "type": "color", "value": "#FBBF24" },
    "color.bg": { "type": "color", "value": "#121218" },
    "color.bg-card": { "type": "color", "value": "#1E1E28" },
    "color.text": { "type": "color", "value": "#F9FAFB" },
    "color.text-muted": { "type": "color", "value": "#9CA3AF" },
    "color.border": { "type": "color", "value": "#374151" },
    "color.success": { "type": "color", "value": "#10B981" },
    "spacing.sm": { "type": "number", "value": 8 },
    "spacing.md": { "type": "number", "value": 16 },
    "spacing.lg": { "type": "number", "value": 24 },
    "spacing.xl": { "type": "number", "value": 32 },
    "spacing.2xl": { "type": "number", "value": 48 },
    "spacing.3xl": { "type": "number", "value": 64 },
    "spacing.4xl": { "type": "number", "value": 80 },
    "radius.md": { "type": "number", "value": 8 },
    "radius.lg": { "type": "number", "value": 12 },
    "radius.xl": { "type": "number", "value": 16 },
    "font.primary": { "type": "string", "value": "Inter, system-ui, sans-serif" },
    "font.mono": { "type": "string", "value": "Fira Code, Consolas, monospace" }
  }
}